          },
          {
            "name": "new_tip_count",
            "type": "u64"
          },
          {
            "name": "new_tip_lamports",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "TipRecord",
      "docs": [
        "On-chain receipt for a tip. Lives at PDA",
        "`[\"tip\", sender_pubkey, tip_id_le_bytes]`. Sender, recipient, and",
        "amount are immutable once written; this is a settled history row."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "sender",
            "type": "pubkey"
          },
          {
            "name": "recipient",
            "type": "pubkey"
          },
          {
            "name": "sender_tid",
            "type": "u64"
          },
          {
            "name": "recipient_tid",
            "type": "u64"
          },
          {
            "name": "amount",
            "type": "u64"
          },
          {
            "name": "tip_id",
            "type": "u64"
          },
          {
            "name": "created_at",
            "type": "i64"
          },
          {
            "name": "target_hash",
            "docs": [
              "Optional anchor to a piece of content the tip is for (e.g. the",
              "blake3 hash of a tweet). Zeroed when `has_target` is false."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "has_target",
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    }
  ]
