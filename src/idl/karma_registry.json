            "type": "pubkey"
          },
          {
            "name": "reward_amount",
            "type": "u64"
          },
          {
            "name": "new_task_count",
            "type": "u64"
          },
          {
            "name": "new_task_reward_lamports",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "TipKarmaRecorded",
      "type": {
        "kind": "struct",
        "fields": [
