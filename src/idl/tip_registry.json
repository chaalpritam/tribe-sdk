{
  "address": "TipReg1111111111111111111111111111111111111",
  "metadata": {
    "name": "tip_registry",
    "version": "0.1.0",
    "spec": "0.1.0",
    "description": "On-chain tip records for the Tribe decentralized social protocol"
  },
  "instructions": [
    {
      "name": "init_sender_state",
      "docs": [
        "One-time per-sender setup. Creates the SenderTipState PDA which",
        "tracks a monotonic `next_tip_id` so each tip has a deterministic",
        "PDA without needing a wall-clock seed."
      ],
      "discriminator": [
        71,
        192,
        153,
        221,
        140,
        136,
        155,
        192
      ],
      "accounts": [
        {
          "name": "sender_state",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [
                  116,
                  105,
                  112,
                  45,
                  115,
                  101,
                  110,
                  100,
                  101,
                  114
                ]
              },
              {
                "kind": "account",
                "path": "sender"
              }
            ]
          }
        },
        {
          "name": "sender",
          "writable": true,
          "signer": true
        },
        {
          "name": "system_program",
          "address": "11111111111111111111111111111111"
        }
      ],
      "args": [
        {
          "name": "sender_tid",
          "type": "u64"
        }
      ]
    },
    {
      "name": "send_tip",
      "docs": [
        "Send a tip from the signer to `recipient`, transferring `amount`",
        "lamports via the System Program and recording a TipRecord PDA",
        "keyed by (sender, tip_id). Optionally anchor the tip to a",
        "content hash (e.g. the blake3 hash of a tweet)."
      ],
      "discriminator": [
        231,
        88,
        56,
        242,
        241,
        6,
        31,
        59
      ],
      "accounts": [
        {
          "name": "sender_state",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [
                  116,
                  105,
                  112,
                  45,
                  115,
                  101,
                  110,
                  100,
                  101,
                  114
                ]
              },
              {
                "kind": "account",
                "path": "sender"
              }
            ]
          }
        },
        {
          "name": "tip_record",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [
                  116,
                  105,
                  112
                ]
              },
              {
                "kind": "account",
                "path": "sender"
              },
              {
                "kind": "account",
                "path": "sender_state.next_tip_id",
                "account": "SenderTipState"
              }
            ]
          }
        },
        {
          "name": "sender",
          "writable": true,
          "signer": true,
          "relations": [
            "sender_state"
          ]
        },
        {
          "name": "recipient",
          "docs": [
            "via the System Program transfer below. The off-chain client is",
            "responsible for ensuring it matches `recipient_tid`'s custody",
            "address from tid-registry."
          ],
          "writable": true
        },
        {
          "name": "system_program",
          "address": "11111111111111111111111111111111"
        }
      ],
      "args": [
        {
          "name": "recipient_tid",
          "type": "u64"
        },
        {
          "name": "amount",
          "type": "u64"
        },
        {
          "name": "target_hash",
          "type": {
            "array": [
              "u8",
              32
            ]
          }
        },
        {
          "name": "has_target",
          "type": "bool"
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "SenderTipState",
      "discriminator": [
        223,
        209,
        200,
        73,
        45,
        19,
        244,
        190
      ]
    },
    {
      "name": "TipRecord",
      "discriminator": [
        43,
        243,
        62,
        130,
        183,
        4,
        81,
        185
      ]
    }
  ],
  "events": [
    {
      "name": "SenderTipStateInitialized",
      "discriminator": [
        231,
        146,
        41,
        18,
        101,
        243,
        247,
        137
      ]
    },
    {
      "name": "TipSent",
      "discriminator": [
        124,
        3,
        185,
        130,
        232,
        65,
        132,
        235
      ]
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "ZeroAmount",
      "msg": "Tip amount must be greater than zero"
    },
    {
      "code": 6001,
      "name": "SelfTip",
      "msg": "Sender and recipient TIDs must differ"
    },
    {
      "code": 6002,
      "name": "SenderTidMismatch",
      "msg": "Sender state TID does not match the seed-bound sender"
    }
  ],
  "types": [
    {
      "name": "SenderTipState",
      "docs": [
        "Per-sender tip counter. Lives at PDA `[\"tip-sender\", sender_pubkey]`.",
        "Each tip the sender sends consumes the current `next_tip_id` and",
        "increments it, so tip PDAs are deterministic and globally unique",
        "per sender without needing a wall-clock seed."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "sender",
            "type": "pubkey"
          },
          {
            "name": "sender_tid",
            "type": "u64"
          },
          {
            "name": "next_tip_id",
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "SenderTipStateInitialized",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "sender",
            "type": "pubkey"
          },
          {
            "name": "sender_tid",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "TipRecord",
      "docs": [
        "On-chain receipt for a tip. Lives at PDA",
        "`[\"tip\", sender_pubkey, tip_id_le_bytes]`. Sender, recipient, and",
        "amount are immutable once written; this is a settled history row."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "sender",
            "type": "pubkey"
          },
          {
            "name": "recipient",
            "type": "pubkey"
          },
          {
            "name": "sender_tid",
            "type": "u64"
          },
          {
            "name": "recipient_tid",
            "type": "u64"
          },
          {
            "name": "amount",
            "type": "u64"
          },
          {
            "name": "tip_id",
            "type": "u64"
          },
          {
            "name": "created_at",
            "type": "i64"
          },
          {
            "name": "target_hash",
            "docs": [
              "Optional anchor to a piece of content the tip is for (e.g. the",
              "blake3 hash of a tweet). Zeroed when `has_target` is false."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "has_target",
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "TipSent",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "sender",
            "type": "pubkey"
          },
          {
            "name": "recipient",
            "type": "pubkey"
          },
          {
            "name": "sender_tid",
            "type": "u64"
          },
          {
            "name": "recipient_tid",
            "type": "u64"
          },
          {
            "name": "amount",
            "type": "u64"
          },
          {
            "name": "tip_id",
            "type": "u64"
          },
          {
            "name": "has_target",
            "type": "bool"
          },
          {
            "name": "target_hash",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          }
        ]
      }
    }
  ]
}